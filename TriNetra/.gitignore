# ====================================================================
# TriNetra Master Gitignore
# ====================================================================

# --- System & IDE Files ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- Zoho Catalyst Configurations ---
# Do NOT ignore catalyst.json or .catalystrc as they contain project mappings,
# but ignore local deployment logs or cache files generated by the CLI.
.catalyst/
catalyst-debug.log
catalyst-error.log
.deploy/

# --- Python Backend (FastAPI / AppSail) ---
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments (Python)
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# --- Frontend Client (React / Node.js) ---
node_modules/
/client/node_modules/
/trinetra-client/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Production Build Directories
dist/
/client/dist/
/trinetra-client/dist/
out/
.next/

# --- Security & Credentials ---
*.pem
*.key
*.secret
.env*.local